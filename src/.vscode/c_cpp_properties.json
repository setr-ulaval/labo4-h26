{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceRoot}",
                "${env.HOME}/linux-build/include",
                "${env.HOME}/linux-build/arch/arm/include",
                "${env.HOME}/linux-build/arch/arm/include/generated/",
                "${env.HOME}/linux-build/arch/arm/include/uapi/",
                "${env.HOME}/linux-build/arch/arm/include/generated/uapi/",
                "${env.HOME}/arm-cross-comp-env/arm-raspbian-linux-gnueabihf/arm-raspbian-linux-gnueabihf/sysroot/usr/lib/gcc/arm-linux-gnueabihf/14/include/",
            ],
            "defines": [
                "__ARM_PCS_VFP", 
                "__KERNEL__", "MODULE"
            ],
            "intelliSenseMode": "linux-gcc-arm",
            "browse": {
                "path": [
                    "${workspaceRoot}"
                ],
                "limitSymbolsToIncludedHeaders": true,
                "databaseFilename": ""
            },
            "compilerPath": "${env.HOME}/arm-cross-comp-env/arm-raspbian-linux-gnueabihf/bin/arm-raspbian-linux-gnueabihf-gcc",
            "cStandard": "gnu17",
            "cppStandard": "gnu++17"
        }
    ],
    "version": 4
}
